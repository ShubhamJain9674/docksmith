FROM alpine:3.19

WORKDIR /app

# 1. Match only top-level .txt files
COPY *.txt /app/txt/

# 2. Match only top-level .py files
COPY *.py /app/py/

# 3. Recursive glob (all .txt files anywhere)
COPY **/*.txt /app/alltxt/

# 4. Nested glob (only inside data folder)
COPY data/**/*.log /app/logs/

CMD ["sh", "-c", "echo '--- /app ---' && ls -R /app"]
